## smoove and cnvnator workflow


samples, = glob_wildcards("{sample}.m.md.bam")
#chromosomes, = glob_wildcards("genome/{chrom}.fa")

RESULTS_DIR = "results/"
SMOOVE_DIR = RESULTS_DIR + "smoove/"
CNV_DIR = RESULTS_DIR + "cnvnator/"
GENOTYPE_DIR = RESULTS_DIR + "smoove/genotyped/"
GENOME_FULL = "/home/eherman/scratch/Stothard/1000bulls_round7_ReadMapping/Reference/ARS-UCD1.2_Btau5.0.1Y.fa"
PARTITION = 1000
ANNOTATION_VCF = "ARS-UCD1.2_Btau5.0.1Y.gff"

rule final:
    input:
        expand(CNV_DIR + "{sample}.cnvnator.txt", sample=samples),
        expand(GENOTYPE_DIR + "results.smoove.square.anno.filter.vcf.gz")


#########################################################################################
# runs smoove/lumpy on bam files
#########################################################################################

rule smoove_call:
    input:
        "{sample}.m.md.bam"
    params:
        sam = lambda wildcards: wildcards.sample
    threads: 2
    resources:
        cores = 2,
        runtime = 60,
        mem_mb = 16000,
    output:
        SMOOVE_DIR + "{sample}-smoove.genotyped.vcf.gz"
    shell:
        """
        module load samtools 
        module load htslib 
        module load bcftools
        smoove call --outdir {SMOOVE_DIR} --name {params.sam} --fasta {GENOME_FULL} -p {threads} --genotype {input}
        """

rule smoove_merge:
    input:
        expand(SMOOVE_DIR + "{sample}-smoove.genotyped.vcf.gz", sample=samples)
    params:
        SMOOVE_DIR + "*.genotyped.vcf.gz"
    threads: 2
    resources:
        cores = 2,
        runtime = 60,
        mem_mb = 8000,
    output:
        SMOOVE_DIR + "merged.sites.vcf.gz"
    shell:
        """
        module load samtools 
        module load htslib 
        module load bcftools
        smoove merge --name merged -f {GENOME_FULL} --outdir {SMOOVE_DIR} {params}
        """

rule smoove_genotype:
    input:
        bam = "{sample}.m.md.bam",
        merged = SMOOVE_DIR + "merged.sites.vcf.gz"
    params:
        sam = lambda wildcards: wildcards.sample
    threads: 2
    resources:
        cores = 2,
        runtime = 60,
        mem_mb = 8000,
    output:
        GENOTYPE_DIR + "{sample}-joint-smoove.genotyped.vcf"
    shell:
        """
        module load samtools 
        module load htslib 
        module load bcftools
        smoove genotype -d -x -p {threads} --name {params.sam}-joint-smoove --outdir {SMOOVE_DIR} --fasta {GENOME_FULL} --vcf {input.merged} {input.bam}
        """

rule smoove_paste:
    input:
        expand(GENOTYPE_DIR + "{sample}-joint-smoove.genotyped.vcf", sample=samples)
    output:
        GENOTYPE_DIR + "results.smoove.square.vcf.gz"
    params:
        GENOTYPE_DIR + "*.vcf.gz"
    threads: 2
    resources:
        cores = 2,
        runtime = 60,
        mem_mb = 8000,
    shell:
        """
        module load samtools 
        module load htslib 
        module load bcftools
        smoove paste --name results {params}
        """

rule smoove_annotate:
    input:
        square = GENOTYPE_DIR + "results.smoove.square.vcf.gz",
        annot = ANNOTATION_VCF
    output:
        GENOTYPE_DIR + "results.smoove.square.anno.vcf.gz"
    threads: 2
    resources:
        cores = 2,
        runtime = 60,
        mem_mb = 8000,
    shell:
        """
        module load samtools 
        module load htslib 
        module load bcftools
        smoove annotate --gff {input.annot} {input.square} | bgzip -c > {output}
        """

rule smoove_filter:
    input:
        GENOTYPE_DIR + "results.smoove.square.anno.vcf.gz"
    output:
        GENOTYPE_DIR + "results.smoove.square.anno.filter.vcf.gz"
    threads: 2
    resources:
        cores = 2,
        runtime = 60,
        mem_mb = 8000,
    shell:
        """
        module load snpeff
        cat {input} | java -Xmx8g -jar /cvmfs/soft.computecanada.ca/easybuild/software/2017/Core/snpeff/4.3t/SnpSift.jar \
        filter " ( MSHQ > 3 ) | (( SVTYPE = 'DEL') & ( GEN[*].DHFFC < 0.7)) | (( SVTYPE = 'DUP') & ( GEN[*].DHFFC < 1.25)) " > {output}
        """
    


#########################################################################################
# runs CNVnator on bam files
#########################################################################################
     
rule cnvnator:
    input:
         "{sample}.m.md.bam"
    params:
        genome = "genome",
        root = lambda wildcards: wildcards.sample
    resources:
        cores = 4,
        runtime = 120,
        mem_mb = 16000,
    output:
        CNV_DIR + "{sample}.cnvnator.txt"
    
    shell:
         """
         module load gcc/8.3.0
         module load cnvnator 
         module load root
         cnvnator -root {params.root}.root -tree {input}
         cnvnator -root {params.root}.root -his {PARTITION} -d {params.genome}
         cnvnator -root {params.root}.root -stat {PARTITION}
         cnvnator -root {params.root}.root -partition {PARTITION}
         cnvnator -root {params.root}.root -call {PARTITION} > {output}
         """